# Stage providers
SURFACE_PROVIDER=rule
SEMANTIC_PROVIDER=gemini

# Facilities database
FACILITIES_JSON_PATH=./facilities.json

# Gemini
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash
SEMANTIC_GEMINI_MODEL=gemini-2.5-pro

# Gemini proxy (optional)
# GEMINI_PROXY_BASE_URL=https://api2.qiandao.mom/v1

# Qwen
QWEN_API_KEY=your_qwen_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
SEMANTIC_QWEN_MODEL=qwen-max
